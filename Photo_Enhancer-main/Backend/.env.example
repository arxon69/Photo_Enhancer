# =============================================================================
# DJANGO CORE SETTINGS
# =============================================================================

# SECURITY WARNING: Change this in production!
SECRET_KEY=your-very-secret-key-change-this-in-production-at-least-50-characters-long

# Set to False in production
DEBUG=False

# Comma-separated list of allowed hosts
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com,*.yourdomain.com

# Comma-separated list of trusted origins for CSRF
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# =============================================================================
# DATABASE - PostgreSQL
# =============================================================================

# SQLite (for local development only):
DATABASE_URL=sqlite:///db.sqlite3

# PostgreSQL (for production):
# DATABASE_URL=postgres://username:password@localhost:5432/photoenhancer

# PostgreSQL connection pool settings
DB_MIN_CONNS=1
DB_MAX_CONNS=20
DB_CONN_MAX_AGE=300

# =============================================================================
# REDIS CACHE & CELERY
# =============================================================================

# Redis URL for caching and Celery broker
# REDIS_URL=redis://localhost:6379/1

# Separate Celery broker URL (optional, defaults to REDIS_URL)
# CELERY_BROKER_URL=redis://localhost:6379/2

# Separate Celery result backend (optional)
# CELERY_RESULT_BACKEND=redis://localhost:6379/3

# =============================================================================
# SECURITY SETTINGS (Enable these in production)
# =============================================================================

# Force HTTPS redirect
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=31536000
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# Admin email for error notifications
ADMIN_EMAIL=admin@yourdomain.com

# =============================================================================
# CORS SETTINGS
# =============================================================================

# Comma-separated list of allowed origins for CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# =============================================================================
# AMAZON S3 / CLOUD STORAGE
# =============================================================================

# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_STORAGE_BUCKET_NAME=your-bucket-name
# AWS_S3_REGION_NAME=us-east-1
# AWS_S3_CUSTOM_DOMAIN=cdn.yourdomain.com

# =============================================================================
# EMAIL SETTINGS
# =============================================================================

# For development (console output):
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# For production (SMTP):
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
# DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# =============================================================================
# LOGGING
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
